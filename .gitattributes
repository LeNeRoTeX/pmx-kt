# Default: let git decide on text vs binary
* text=auto eol=lf

# Shell scripts must always be LF, otherwise CRLF breaks the shebang on Linux.
gradlew      text eol=lf
*.sh         text eol=lf

# Windows batch scripts must keep CRLF.
gradlew.bat  text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binary assets should never be touched by line-ending normalization.
*.jar        binary
*.png        binary
*.jpg        binary
*.gif        binary
*.ico        binary
